APP_ENV=dev
PROD=false
HOST=0.0.0.0
PORT=8080
PUBLIC_PATH=public

MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=viggo-nubeadmin
MONGO_DISCONNECT_EXIT_DELAY_MS=30000

JWT_SEED=replace-with-a-long-random-secret
AUTH_COOKIE_NAME=viggo_admin_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE_MS=172800000

WEB_SERVICE_URL=http://localhost:8080
WEB_CLIENT_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

MAILER_EMAIL=
MAILER_SECRET_KEY=
MAILER_SERVICE=
MAILER_HOST=
MAILER_PORT=465
MAILER_SECURE=true
MAILER_FROM_NAME=Viggo

SECRET_STRIPE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CURRENCY=mxn
STRIPE_ENABLED=false
STRIPE_MOCK_ENABLED=true

SYNC_SERVICE_TOKEN=replace-with-an-independent-service-token
