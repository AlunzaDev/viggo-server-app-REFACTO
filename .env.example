BACKEND_IMAGE=viggo-server-app-refacto:local
APP_ENV=prod
BACKEND_ENV_FILE=.env.prod
BACKEND_PORT=8080

# Docker build bakes the app config from BACKEND_ENV_FILE into /project/.env
# inside the image. The remaining values below are still useful for local
# node runs and as a template for .env.dev / .env.prod.
JWT_SEED=viggo-dev-seed

PROD=true
MONGO_DB_NAME=VIGGO
MONGO_URL=mongodb://viggo_user:viggo_pass@mongo-db:27017/VIGGO?authSource=admin
MONGO_USER=viggo_user
MONGO_PASS=viggo_pass
MONGO_DISCONNECT_EXIT_DELAY_MS=30000

MAILER_EMAIL=
MAILER_SECRET_KEY=
MAILER_SERVICE=
MAILER_HOST=
MAILER_PORT=465
MAILER_SECURE=true
MAILER_FROM_NAME=Viggo

PUBLIC_PATH=public
HOST=0.0.0.0
PORT=8080
WEB_SERVICE_URL=http://localhost:8080
WEB_CLIENT_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUTH_COOKIE_NAME=viggo_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE_MS=172800000

SECRET_STRIPE_KEY=sk_test_xxx
STRIPE_CURRENCY=mxn
STRIPE_ENABLED=false
STRIPE_MOCK_ENABLED=true

BARRIER_SOCKET_REQUIRED=false
BARRIER_SOCKET_TIMEOUT_MS=5000
