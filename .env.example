BACKEND_IMAGE=cejadali/cobrocaja-backend:latest
APP_ENV=prod
BACKEND_ENV_FILE=.env.prod
BACKEND_PORT=8080

# Docker build bakes the app config from BACKEND_ENV_FILE into /project/.env
# inside the image. The remaining values below are still useful for local
# node runs and as a template for .env.dev / .env.prod.
MQTT_SERVER=
CLIENT_ID=
JWT_SEED=

PROD=false
# In APP_ENV=dev, true makes the local backend use MONGO_URL,
# MONGO_DB_NAME, WEB_SERVICE_URL and WEB_CLIENT_URL from .env.prod.
USE_PROD_SERVICES=false
MONGO_DB_NAME=
MONGO_URL=
MONGO_USER=
MONGO_PASS=
MONGO_DISCONNECT_EXIT_DELAY_MS=30000

MAILER_EMAIL=
MAILER_SECRET_KEY=
MAILER_SERVICE=

PUBLIC_PATH=public
PORT=8080
WEB_SERVICE_URL=http://localhost:8080
WEB_CLIENT_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=
AUTH_COOKIE_NAME=sikk_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_MAX_AGE_MS=172800000
WEB_PUSH_VAPID_SUBJECT=mailto:soporte@example.com
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=

# DEPLOY
# docker buildx build --secret id=backend_env,src=.env.prod --build-arg APP_ENV=prod -t cejadali/sikkounter-backend:latest --push .
# APP_ENV=prod BACKEND_IMAGE=cejadali/sikkounter-backend:latest docker compose up -d --no-deps backend
